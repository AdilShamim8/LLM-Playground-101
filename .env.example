# ── Core Settings ──────────────────────────────────────────────────
PROJECT_NAME=llm_playground
ENVIRONMENT=development           # development | staging | production
DEBUG=true
DEV_MODE=true

# ── API Settings ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Authentication ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://llm_user:llm_password@localhost:5432/llm_playground
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=llm_password
POSTGRES_DB=llm_playground

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Model Storage ──────────────────────────────────────────────────
MODEL_CHECKPOINT_DIR=./checkpoints
DATA_DIR=./data
TOKENIZER_DIR=./tokenizers

# ── Training ───────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0
WANDB_PROJECT=llm_playground
WANDB_API_KEY=your-wandb-api-key-here

# ── UI ─────────────────────────────────────────────────────────────
UI_PORT=7860
API_BASE=http://localhost:8000/api/v1

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log